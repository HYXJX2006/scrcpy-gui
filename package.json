{
  "name": "scrcpy-gui",
  "version": "1.0.2",
  "description": "scrcpy 可视化界面 - 安卓设备投屏控制工具",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node --experimental-loader ./scripts/win-esm-loader.mjs ./node_modules/electron-vite/dist/cli.js dev",
    "build": "node --experimental-loader ./scripts/win-esm-loader.mjs ./node_modules/electron-vite/dist/cli.js build",
    "preview": "node --experimental-loader ./scripts/win-esm-loader.mjs ./node_modules/electron-vite/dist/cli.js preview",
    "pack": "node --experimental-loader ./scripts/win-esm-loader.mjs ./node_modules/electron-vite/dist/cli.js build && electron-builder --win --dir",
    "dist": "node --experimental-loader ./scripts/win-esm-loader.mjs ./node_modules/electron-vite/dist/cli.js build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@unocss/reset": "^66.7.2",
    "electron-store": "^10.1.0",
    "naive-ui": "^2.41.0",
    "pinia": "^3.0.2",
    "unocss": "^66.7.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.0",
    "unplugin-auto-import": "^19.1.0",
    "unplugin-vue-components": "^28.0.0",
    "vite": "^6.4.3",
    "vue-tsc": "^2.2.0"
  },
  "optionalDependencies": {
    "@oxc-parser/binding-wasm32-wasi": "^0.137.0",
    "@oxc-parser/binding-win32-x64-msvc": "^0.137.0"
  }
}
